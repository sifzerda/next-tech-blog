generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int       @id @default(autoincrement())
  name     String
  email    String    @unique
  password String

  // Relations
  projects Project[]
  comments Comment[]

  @@map("user")
}

model Project {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  dateCreated DateTime  @default(now())

  // Relations
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  comments    Comment[]

  @@map("project")
}

model Comment {
  id          Int       @id @default(autoincrement())
  text        String?
  dateCreated DateTime  @default(now())

  // Relations
  projectId   Int
  project     Project   @relation(fields: [projectId], references: [id])
  userId      Int
  user        User      @relation(fields: [userId], references: [id])

  @@map("comment")
}